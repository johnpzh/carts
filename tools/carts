#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CARTS_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${PYTHON:-python}"

add_lib_path() {
  local lib_dir="$1"
  if [[ -d "${lib_dir}" ]]; then
    case ":${CARTS_LIBRARY_PATHS:-}:" in
      *":${lib_dir}:"*) ;;
      *) CARTS_LIBRARY_PATHS="${CARTS_LIBRARY_PATHS:+${CARTS_LIBRARY_PATHS}:}${lib_dir}" ;;
    esac
  fi
}

PYTHON_PREFIX="$("${PYTHON_BIN}" -c 'import sys; print(sys.prefix)' 2>/dev/null || true)"
if [[ -n "${PYTHON_PREFIX}" ]]; then
  add_lib_path "${PYTHON_PREFIX}/lib"
fi
if [[ -n "${CONDA_PREFIX:-}" ]]; then
  add_lib_path "${CONDA_PREFIX}/lib"
fi
add_lib_path "${CARTS_DIR}/.install/carts/lib"
add_lib_path "${CARTS_DIR}/.install/arts/lib"

if [[ -n "${CARTS_LIBRARY_PATHS:-}" ]]; then
  export DYLD_LIBRARY_PATH="${CARTS_LIBRARY_PATHS}${DYLD_LIBRARY_PATH:+:${DYLD_LIBRARY_PATH}}"
  export LD_LIBRARY_PATH="${CARTS_LIBRARY_PATHS}:${CARTS_DIR}/.install/llvm/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
fi

exec "${PYTHON_BIN}" "${SCRIPT_DIR}/carts_cli.py" "$@"
