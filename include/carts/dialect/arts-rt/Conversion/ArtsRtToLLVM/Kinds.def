///==========================================================================///
/// File: Kinds.def
///
/// Defines ARTS directives, clauses, and runtime calls for code generation.
///==========================================================================///

/// ARTS_CONSTANTS - ARTS runtime constants
/// ARTS_RTL - ARTS runtime function definitions

///===----------------------------------------------------------------------===///
/// ARTS typedefs
///===----------------------------------------------------------------------===///
#define ArtsGuid Int64
#define ArtsGuidPtr Int64Ptr
#define ArtsPtr Int64
#define ArtsType Int32
#define SizeTy PtrSize
#define Void builder.getNoneType()

#ifdef ARTS_CONSTANTS
///===----------------------------------------------------------------------===///
/// ARTS Constants
///===----------------------------------------------------------------------===///
/// NULL_GUID constant
#define NULL_GUID ((ArtsGuid)0x0)

/// EDT constants
#define DEFAULT_EDT_SLOT 0

/// Hint constant: use the node running the current EDT
#define ARTS_HINT_CURRENT_NODE ((Int32) - 1)

/// arts_latch_event_slot_t enum values (from arts v2 arts.h)
#define ARTS_EVENT_LATCH_DECR_SLOT 0
#define ARTS_EVENT_LATCH_INCR_SLOT 1
#define ARTS_EVENT_UPDATE 2

/// arts_type_t enum values (from arts v2 arts.h) — sequential, no gaps
#define ARTS_NULL 0
#define ARTS_EDT 1
#define ARTS_EVENT 2
#define ARTS_EPOCH 3
#define ARTS_CALLBACK 4
#define ARTS_BUFFER 5
#define ARTS_DB 6
#define ARTS_LAST_TYPE 7

/// arts_db_access_mode_t enum values (from arts v2 arts.h)
#define DB_MODE_NULL 0
#define DB_MODE_RO 1
#define DB_MODE_EW 2
#define DB_MODE_RW 3
#define DB_MODE_VALUE 4
#define DB_MODE_PTR 5
#define DB_MODE_LC_SYNC 6
#define DB_MODE_LC_NO_COPY 7
#define DB_MODE_MEMSET 8

/// arts_db_types_t enum values (from arts v2 arts.h)
#define ARTS_DB_DEFAULT 0
#define ARTS_DB_LOCAL 1
#define ARTS_DB_GPU 2
#define ARTS_DB_LC 3

/// arts_edt_types_t enum values (from arts v2 arts.h)
#define ARTS_EDT_DEFAULT 0
#define ARTS_EDT_GPU 1

/// arts_event_types_t enum values (from arts v2 arts.h)
#define ARTS_EVENT_LATCH 0
#define ARTS_EVENT_ONCE 1
#define ARTS_EVENT_STICKY 2
#define ARTS_EVENT_IDEM 3
#define ARTS_EVENT_COUNTED 4
#define ARTS_EVENT_CHANNEL 5
#endif // ARTS_CONSTANTS

///===----------------------------------------------------------------------===///
/// Types used in RT structs or RT functions
///===----------------------------------------------------------------------===///
///{
#ifndef ARTS_TYPE
#define ARTS_TYPE(VarName, InitValue)
#endif

/// Macro for integer types with a specific bit width
#define __ARTS_INTEGER_TYPE(VarName, BitWidth)                                 \
  ARTS_TYPE(VarName, mlir::IntegerType::get(context, BitWidth))

/// Macro for specific types (e.g., float, double)
#define __ARTS_TYPE(VarName, TypeCreator)                                      \
  ARTS_TYPE(VarName, TypeCreator(context))

/// Macro for pointer types
#define __ARTS_PTR_TYPE(VarName, ElemType)                                     \
  ARTS_TYPE(VarName, mlir::MemRefType::get({ShapedType::kDynamic}, ElemType))

/// Define basic LLVM types
__ARTS_TYPE(Float, mlir::Float32Type::get)
__ARTS_TYPE(Double, mlir::Float64Type::get)

/// Define integer types
__ARTS_INTEGER_TYPE(PtrSize, llvmDL->getPointerSizeInBits())
__ARTS_INTEGER_TYPE(Int1, 1)
__ARTS_INTEGER_TYPE(Int8, 8)
__ARTS_INTEGER_TYPE(Int16, 16)
__ARTS_INTEGER_TYPE(Int32, 32)
__ARTS_INTEGER_TYPE(Int64, 64)

/// Define pointer types
__ARTS_PTR_TYPE(VoidPtr, PtrSize)
__ARTS_PTR_TYPE(VoidPtrPtr, VoidPtr)
__ARTS_PTR_TYPE(Int1Ptr, Int1)
__ARTS_PTR_TYPE(Int8Ptr, Int8)
__ARTS_PTR_TYPE(Int16Ptr, Int16)
__ARTS_PTR_TYPE(Int32Ptr, Int32)
__ARTS_PTR_TYPE(Int64Ptr, Int64)
__ARTS_PTR_TYPE(Int8PtrPtr, Int8Ptr)

/// Raw LLVM pointer for runtime functions that return void*
__ARTS_TYPE(RawPtr, mlir::LLVM::LLVMPointerType::get)

#undef __ARTS_INTEGER_TYPE
#undef __ARTS_TYPE
#undef __ARTS_PTR_TYPE
#undef ARTS_TYPE
///}

///===----------------------------------------------------------------------===///
/// Struct types
///===----------------------------------------------------------------------===///
///{
#ifndef ARTS_STRUCT_TYPE
#define ARTS_STRUCT_TYPE(VarName, StructName, Packed, ...)
#endif

#define __ARTS_STRUCT_TYPE(VarName, Name, Packed, ...)                         \
  ARTS_STRUCT_TYPE(VarName, "struct." #Name, Packed, __VA_ARGS__)

/// typedef struct {
///   arts_guid_t guid;
///   void *ptr;
///   arts_db_access_mode_t mode;
///   uint32_t flags;
///   uint64_t slice_offset;
///   uint64_t slice_size;
/// } arts_edt_dep_t;
__ARTS_STRUCT_TYPE(ArtsEdtDep, arts_edt_dep_t, false, ArtsGuid, llvmPtr,
                   ArtsType, Int32, Int64, Int64)

/// typedef struct {
///   unsigned int route;
///   uint64_t id;
/// } arts_hint_t;
__ARTS_STRUCT_TYPE(ArtsHintType, arts_hint_t, false, Int32, Int64)

#undef __ARTS_STRUCT_TYPE
#undef ARTS_STRUCT_TYPE

///===----------------------------------------------------------------------===///
/// Function types
///===----------------------------------------------------------------------===///
///{
#ifndef ARTS_FUNCTION_TYPE
#define ARTS_FUNCTION_TYPE(VarName, ReturnType, ...)
#endif

#define __ARTS_FUNCTION_TYPE(VarName, ReturnType, ...)                         \
  ARTS_FUNCTION_TYPE(VarName, ReturnType, __VA_ARGS__)

/// typedef void (*arts_edt_t)(uint32_t paramc, const uint64_t *paramv,
///                            uint32_t depc, arts_edt_dep_t depv[]);
__ARTS_FUNCTION_TYPE(EdtFn, Void, Int32, Int64Ptr, Int32, ArtsEdtDepPtr)

/// void main_edt(uint32_t paramc, const uint64_t *paramv,
///               uint32_t depc, arts_edt_dep_t depv[]);
__ARTS_FUNCTION_TYPE(ArtsMainFn, Void, Int32, Int64Ptr, Int32, ArtsEdtDepPtr)

/// void init_per_node(unsigned int nodeId, int argc, char **argv)
__ARTS_FUNCTION_TYPE(InitPerNodeFn, Void, Int32, Int32, Int8PtrPtr)

/// void init_per_worker(unsigned int nodeId, unsigned int workerId, int argc,
///                      char** argv)
__ARTS_FUNCTION_TYPE(InitPerWorkerFn, Void, Int32, Int32, Int32, Int8PtrPtr)

/// int main(int argc, char** argv)
__ARTS_FUNCTION_TYPE(MainFn, Int32, Int32, Int8PtrPtr)
#undef __ARTS_FUNCTION_TYPE
#undef ARTS_FUNCTION_TYPE
///}

///===----------------------------------------------------------------------===///
/// Runtime
///===----------------------------------------------------------------------===///
///{
#ifdef ARTS_RTL_FUNCTIONS

#define __ARTS_RTL(Name, ReturnType, ...)                                      \
  ARTS_RTL(ARTSRTL_##Name, #Name, ReturnType, __VA_ARGS__)

#ifndef ARTS_RTL_ATTRS
#define ARTS_RTL_ATTRS(Enum, FnAttrSet, RetAttrSet, ArgAttrSets)
#endif

#define __ARTS_RTL_ATTRS(Name, FnAttrSet, RetAttrSet, ArgAttrSets)             \
  ARTS_RTL_ATTRS(ARTSRTL_##Name, FnAttrSet, RetAttrSet, ArgAttrSets)

/// int arts_rt(int argc, char **argv);
__ARTS_RTL(arts_rt, Int32, Int32, Int8PtrPtr)
__ARTS_RTL_ATTRS(arts_rt, ControlAttrs, SExt,
                 ParamAttrs(SExt, ReadOnlyPtrAttrs))

/// void arts_shutdown();
__ARTS_RTL(arts_shutdown, Void)
__ARTS_RTL_ATTRS(arts_shutdown, ControlAttrs, EmptyAttrs, ParamAttrs())

/// CARTS still calls these runtime entrypoints from insertMainFn() to hand the
/// embedded or external runtime configuration blob to ARTS startup.
/// void artsSetConfigPath(const char *path);
__ARTS_RTL(artsSetConfigPath, Void, Int8Ptr)
__ARTS_RTL_ATTRS(artsSetConfigPath, ControlAttrs, EmptyAttrs,
                 ParamAttrs(ReadOnlyPtrAttrs))

/// void artsSetConfigData(const char *data);
__ARTS_RTL(artsSetConfigData, Void, Int8Ptr)
__ARTS_RTL_ATTRS(artsSetConfigData, ControlAttrs, EmptyAttrs,
                 ParamAttrs(ReadOnlyPtrAttrs))

/// void *arts_malloc(size_t size);
__ARTS_RTL(arts_malloc, VoidPtr, SizeTy)
__ARTS_RTL_ATTRS(arts_malloc, AllocAttrs, ReturnPtrAttrs,
                 ParamAttrs(EmptyAttrs))

/// void *arts_calloc(size_t nmemb, size_t size);
__ARTS_RTL(arts_calloc, VoidPtr, SizeTy, SizeTy)
__ARTS_RTL_ATTRS(arts_calloc, AllocAttrs, ReturnPtrAttrs,
                 ParamAttrs(EmptyAttrs, EmptyAttrs))

/// void arts_free(void *ptr);
__ARTS_RTL(arts_free, Void, VoidPtr)
__ARTS_RTL_ATTRS(arts_free, AllocAttrs, EmptyAttrs, ParamAttrs(ArgPtrAttrs))

/// arts_guid_t arts_guid_reserve(arts_type_t type, unsigned int route);
__ARTS_RTL(arts_guid_reserve, ArtsGuid, ArtsType, Int32)
__ARTS_RTL_ATTRS(arts_guid_reserve, ControlAttrs, EmptyAttrs,
                 ParamAttrs(SExt, ZExt))

/// arts_guid_t arts_guid_reserve_range(arts_type_t type, unsigned int size,
///                                     unsigned int route);
__ARTS_RTL(arts_guid_reserve_range, ArtsGuid, ArtsType, Int32, Int32)
__ARTS_RTL_ATTRS(arts_guid_reserve_range, ControlAttrs, EmptyAttrs,
                 ParamAttrs(SExt, ZExt, ZExt))

/// arts_guid_t arts_guid_from_index(arts_guid_t range_guid, unsigned int idx);
__ARTS_RTL(arts_guid_from_index, ArtsGuid, ArtsGuid, Int32)
__ARTS_RTL_ATTRS(arts_guid_from_index, PureAttrs, EmptyAttrs,
                 ParamAttrs(EmptyAttrs, ZExt))

/// unsigned int arts_guid_get_rank(arts_guid_t guid);
__ARTS_RTL(arts_guid_get_rank, Int32, ArtsGuid)
__ARTS_RTL_ATTRS(arts_guid_get_rank, PureAttrs, ZExt, ParamAttrs(EmptyAttrs))

/// }

